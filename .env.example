# Environment variables for Ticket Management System
# Copy this file to .env and update the values as needed

# Database connection string (example for PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/ticket_management"

# Test database connection string (used when NODE_ENV=test)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_TEST
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/test_ticket_management"

# Secret for encrypting cookies, tokens, etc.
# Generate a strong secret with: openssl rand -base64 32
# Example (replace with your own): qWfYthT5UE9Btrq7NGmeJkiAHygy2fi+ecmQaFO6LBg=
BETTER_AUTH_SECRET="your-generated-secret-here"

# Base URL of the application (used for emails, etc.)
BETTER_AUTH_URL="http://localhost:3000"

# Trusted origins for CORS (comma-separated, no spaces)
TRUSTED_ORIGINS="http://localhost:5173,http://localhost:5174"

# Node environment (development, production, test)
NODE_ENV="development"

# Admin credentials (for initial setup - change after first login)
# IMPORTANT: Change these values before first use!
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changemeimmediately123!"

# OpenAI API Key for AI features (e.g. Polish Reply)
OPENAI_API_KEY=""
